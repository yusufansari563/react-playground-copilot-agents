{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "operation:plan-feature": "node -e \"console.log('Use prompt template: .github/prompts/plan-feature.prompt.md')\"",
    "operation:write-code": "node -e \"console.log('Use prompt template: .github/prompts/write-code.prompt.md')\"",
    "operation:write-tests": "node -e \"console.log('Use prompt template: .github/prompts/write-tests.prompt.md')\"",
    "operation:write-stories": "node -e \"console.log('Use prompt template: .github/prompts/write-stories.prompt.md')\"",
    "operation:write-docs": "node -e \"console.log('Use prompt template: .github/prompts/write-docs.prompt.md')\"",
    "operation:refactor": "node -e \"console.log('Use prompt template: .github/prompts/refactor.prompt.md')\"",
    "operation:optimize": "node -e \"console.log('Use prompt template: .github/prompts/optimize.prompt.md')\"",
    "operation:fix-bugs": "node -e \"console.log('Use prompt template: .github/prompts/fix-bugs.prompt.md')\"",
    "operation:review": "node -e \"console.log('Use prompt template: .github/prompts/review.prompt.md')\"",
    "operation:commit-message": "node -e \"console.log('Use prompt template: .github/prompts/commit-message.prompt.md')\"",
    "operation:pre-commit": "node -e \"console.log('Use prompt template: .github/prompts/pre-commit.prompt.md')\"",
    "operation:post-commit": "node -e \"console.log('Use prompt template: .github/prompts/post-commit.prompt.md')\"",
    "operation:learn": "node -e \"console.log('Use prompt template: .github/prompts/learn.prompt.md')\"",
    "operation:find-resources": "node -e \"console.log('Use prompt template: .github/prompts/find-resources.prompt.md')\"",
    "operation:track-progress": "node -e \"console.log('Use prompt template: .github/prompts/track-progress.prompt.md')\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.99.2",
    "axios": "^1.15.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.73.1",
    "react-router-dom": "^7.14.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.4",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
